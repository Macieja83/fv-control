# Skopiuj do `.env` w katalogu głównym:  cp .env.example .env
# (Nie commituj pliku `.env` — tylko szablony w repozytorium.)
#
# === ZALECANY tryb: prawdziwe lokalne API (spójny z logowaniem, fakturami, BullMQ) ===
# 1) cp backend/.env.example backend/.env  + npm run infra:up
# 2) cd backend && npx prisma migrate deploy && npx prisma db seed
# 3) npm run dev:local
#
# Logowanie: konta z seed (np. admin@fvresta.local / Admin123!) — patrz komentarze w backend/.env.example.
# Gdy poniżej masz FV_RESTA_API_URL, Vite proxy'uje /api → NIE używaj w tym samym pliku „hasła do Vite”
# (FV_RESTA_LOGIN_PASSWORD) do logowania w aplikacji — to hasło służy TYLKO trybowi „sam front” poniżej.
FV_RESTA_API_URL=http://localhost:3000
VITE_USE_MOCK_INVOICES=false
#
# === ALTERNATYWA: tylko frontend (Vite, bez bazy) — szybki podgląd UI ===
# (albo: npm run dev:web  — ładuje nadpisujące wartości z pliku .env.web-only w repo)
# FV_RESTA_API_URL=
# FV_RESTA_LOGIN_PASSWORD=Admin123!
# VITE_USE_MOCK_INVOICES=true
#
# Opcjonalnie w trybie front-only: zaloguj tylko z jednego e-maila (ignorowane, gdy jest FV_RESTA_API_URL).
# FV_RESTA_LOGIN_EMAIL=admin@fvresta.local
#
# Opcjonalnie (dev): e-maile uznawane za Admin platformy, rozdzielone przecinkiem.
# FV_RESTA_DEV_PLATFORM_ADMIN_EMAILS=admin@fvresta.local,kontakt@tuttopizza.pl
#
# Opcjonalnie: e-mail w stopce landing. Domyślnie w kodzie: kontakt@tuttopizza.pl.
# VITE_PUBLIC_SUPPORT_EMAIL=
