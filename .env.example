# Kopiuj do pliku `.env` (nie commituj `.env`).
#
# ─── Tryb A: sam frontend (Vite udaje /api/auth/*) ───
# Ustaw hasło — logowanie sprawdzane tylko po stronie Vite (dowolny e-mail, o ile nie ustawisz FV_RESTA_LOGIN_EMAIL).
FV_RESTA_LOGIN_PASSWORD=ustaw_silne_haslo
#
# Ważne: bez wiersza FV_RESTA_API_URL poniżej Vite NIE proxy'uje GET /api/v1/invoices — lista faktur i Raporty
# nie wczytają bazy (w dev Raporty pokażą wtedy przykładowy seed + baner z instrukcją).

# Opcjonalnie: jeśli ustawione, zaloguje się tylko ten adres (case-insensitive).
# FV_RESTA_LOGIN_EMAIL=manager@resta.biz

# ─── Tryb B: prawdziwe API (np. backend w folderze backend/) — zalecane lokalnie ───
# Proxy przekieruje /api na ten host; logowanie idzie do Fastify. Po `npx prisma db seed` w backend:
#   admin@fvresta.local / Admin123!   albo   kontakt@tuttopizza.pl / Admin123!
FV_RESTA_API_URL=http://localhost:3000
# Gdy API nie działa (błąd logowania / 502), zobacz `npm run dev:web` i plik `.env.web-only` w README.
# (opcjonalnie) Tryb Vite dev — kto ma zakładkę Admin: kontakt@…, admin@fvresta…
# FV_RESTA_DEV_PLATFORM_ADMIN_EMAILS=kontakt@tuttopizza.pl,admin@fvresta.local

# Lista faktur: false = GET /api/v1/invoices (wymaga FV_RESTA_API_URL + zalogowania)
# true = dane demo z seedInvoices() tylko gdy brak sesji; po zalogowaniu lista i Raporty idą z API (baza).
VITE_USE_MOCK_INVOICES=false

# Opcjonalnie: e-mail kontaktowy na landing (mailto). Domyślnie kontakt@tuttopizza.pl.
# VITE_PUBLIC_SUPPORT_EMAIL=kontakt@twojadomena.pl
