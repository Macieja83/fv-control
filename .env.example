# Kopiuj do pliku `.env` (nie commituj `.env`).
#
# ─── Tryb A: sam frontend (Vite udaje /api/auth/*) ───
# Ustaw hasło — logowanie sprawdzane tylko po stronie Vite (dowolny e-mail, o ile nie ustawisz FV_RESTA_LOGIN_EMAIL).
FV_RESTA_LOGIN_PASSWORD=ustaw_silne_haslo

# Opcjonalnie: jeśli ustawione, zaloguje się tylko ten adres (case-insensitive).
# FV_RESTA_LOGIN_EMAIL=manager@resta.biz

# ─── Tryb B: prawdziwe API (np. backend w folderze backend/) ───
# Jeśli ustawisz FV_RESTA_API_URL, proxy przekieruje /api na ten host i NIE używasz FV_RESTA_LOGIN_PASSWORD.
# Uruchom API: cd backend && npm run dev  (domyślnie port 3000)
# Seed: admin@fvresta.local / Admin123!
# FV_RESTA_API_URL=http://localhost:3000

# Lista faktur: false = GET /api/v1/invoices (wymaga FV_RESTA_API_URL + zalogowania)
# true = dane demo z seedInvoices()
# VITE_USE_MOCK_INVOICES=false
