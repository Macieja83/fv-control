generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Legacy JWT / coarse RBAC (kept for token compatibility; extended by Role + user_roles) ---
enum UserRole {
  OWNER
  ADMIN
  ACCOUNTANT
  VIEWER
}

enum InvoiceStatus {
  DRAFT
  RECEIVED
  VERIFIED
  PAID
  REJECTED
  INGESTING
  PENDING_REVIEW
  FAILED_NEEDS_REVIEW
}

enum InvoiceSource {
  MANUAL
  OCR
  EMAIL
  API
}

enum StorageType {
  LOCAL
  S3
}

enum InvoiceEventType {
  CREATED
  UPDATED
  STATUS_CHANGED
  FILE_ADDED
  FILE_REMOVED
  EXPORTED
}

enum PosProvider {
  POS_RESTA
}

/// External ingestion channel (FVControl)
enum IngestionSourceType {
  MAIL_GMAIL
  MAIL_IMAP
  KSEF
  RESTA_API
  MANUAL_UPLOAD
}

enum MailboxProvider {
  GMAIL
  IMAP
}

enum ConnectorType {
  GMAIL
  IMAP_ZENBOX
  KSEF
  RESTA_POS
  MANUAL
}

enum ProcessingJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  DEAD_LETTER
}

enum PipelineStep {
  INGEST
  PERSIST_RAW
  PARSE_METADATA
  EXTRACT
  VALIDATE
  DEDUP
  CLASSIFY
  COMPLIANCE
  EMIT_EVENTS
  AUDIT
}

/// Business intake channel (legal / ops classification); distinct from legacy InvoiceSource.
enum InvoiceIntakeSourceType {
  EMAIL
  UPLOAD
  OCR_SCAN
  KSEF_API
  CASH_REGISTER
}

/// Koszt (zakup) vs sprzedaż wystawiana przez tenant — wpływa na reguły KSeF (własna sprzedaż → TO_ISSUE).
enum InvoiceLedgerKind {
  PURCHASE
  SALE
}

enum InvoiceDocumentKind {
  INVOICE
  CORRECTIVE_INVOICE
  SIMPLIFIED_INVOICE
  RECEIPT_WITH_NIP
  PROFORMA
  OTHER
}

enum LegalChannel {
  KSEF
  OUTSIDE_KSEF
  EXCLUDED
  UNKNOWN
}

enum KsefWorkflowStatus {
  NOT_APPLICABLE
  TO_ISSUE
  SENT
  RECEIVED
  REJECTED
  PENDING
  MANUAL_REVIEW
}

enum InvoiceReviewStatus {
  NEW
  PARSED
  NEEDS_REVIEW
  ACCEPTED
  REJECTED
}

enum AccountingRecordStatus {
  NOT_EXPORTED
  EXPORTED
}

enum InvoiceFileKind {
  PDF
  XML
  IMAGE
  OTHER
}

enum ComplianceEventType {
  INTAKE
  CLASSIFIED
  COMPLIANCE_VALIDATED
  KSEF_SUBMIT_REQUESTED
  DUPLICATE_DETECTED
  EXPORT_READY
  FLAGGED
}

enum AccountingExportStatus {
  PENDING
  COMPLETED
  FAILED
}

enum DuplicateResolution {
  OPEN
  MERGED
  IGNORED
  FALSE_POSITIVE
}

enum IdempotencyLifecycle {
  IN_FLIGHT
  COMPLETED
}

enum IntegrationCredentialKind {
  OAUTH_TOKENS
  IMAP_PASSWORD
  API_KEY
  KSEF_CERT
  GENERIC_SECRET
}

/// Message / attachment tracking for IMAP (Zenbox) ingestion idempotency
enum IngestionChannelProvider {
  ZENBOX_IMAP
}

enum ImapMailboxSyncStatus {
  IDLE
  RUNNING
  ERROR
}

enum AuditEntityType {
  TENANT
  USER
  INVOICE
  DOCUMENT
  INTEGRATION
  WEBHOOK
  SETTINGS
}

enum AgreementStatus {
  PROCESSING
  READY
  FAILED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  SUSPENDED
}

enum SubscriptionProvider {
  MANUAL
  STRIPE
}

enum BillingWebhookProvider {
  STRIPE
  P24
}

enum AuthProvider {
  GOOGLE
}

// --- Core tenant / RBAC ---

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  nip       String?  @unique
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                  User[]
  roles                  Role[]
  contractors            Contractor[]
  invoices               Invoice[]
  integrationsPos        IntegrationPos[]
  documents              Document[]
  mailboxes              Mailbox[]
  ingestionSources       IngestionSource[]
  processingJobs         ProcessingJob[]
  integrationCredentials IntegrationCredential[]
  auditLogs              AuditLog[]
  idempotencyKeys        IdempotencyKey[]
  invoiceDuplicates      InvoiceDuplicate[]
  settings               TenantSetting[]
  extractionRuns         ExtractionRun[]
  invoiceSources         InvoiceSourceRecord[]
  complianceEvents       InvoiceComplianceEvent[]
  accountingExports      AccountingExport[]
  sourceMessages         SourceMessage[]
  agreements             Agreement[]
  subscriptions          Subscription[]
  emailVerificationTokens EmailVerificationToken[]
}

model Permission {
  id    String @id @default(uuid()) @db.Uuid
  key   String @unique
  roles RolePermission[]
}

model Role {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  slug      String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  permissions RolePermission[]
  userLinks   UserRoleLink[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("roles")
}

model RolePermission {
  roleId       String @db.Uuid
  permissionId String @db.Uuid
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRoleLink {
  userId String @db.Uuid
  roleId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email        String   @unique
  passwordHash String?
  emailVerified Boolean @default(true)
  role         UserRole
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens   RefreshToken[]
  invoicesCreated Invoice[]       @relation("InvoiceCreatedBy")
  agreementsCreated Agreement[]   @relation("AgreementCreatedBy")
  invoiceEvents   InvoiceEvent[]
  roleLinks       UserRoleLink[]
  auditLogs       AuditLog[]      @relation("AuditActor")
  authIdentities  AuthIdentity[]
  emailVerificationTokens EmailVerificationToken[]

  @@index([tenantId])
}

model Subscription {
  id                  String               @id @default(uuid()) @db.Uuid
  tenantId            String               @db.Uuid
  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  status              SubscriptionStatus
  provider            SubscriptionProvider @default(MANUAL)
  planCode            String               @default("starter")
  providerCustomerId  String?
  providerSubscriptionId String?
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  trialEndsAt         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([tenantId, status])
  @@map("subscriptions")
}

model EmailVerificationToken {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId     String   @db.Uuid
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([userId, expiresAt])
  @@index([tenantId, expiresAt])
  @@map("email_verification_tokens")
}

model AuthIdentity {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @db.Uuid
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider       AuthProvider
  providerUserId String
  email          String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("auth_identities")
}

model RefreshToken {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash    String    @unique
  expiresAt    DateTime
  createdAt    DateTime  @default(now())
  revokedAt    DateTime?
  replacedById String?   @db.Uuid

  @@index([userId])
  @@index([expiresAt])
}

model Contractor {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @db.Uuid
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  nip       String
  address   String?
  email     String?
  phone     String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  invoices   Invoice[]
  agreements Agreement[]

  @@unique([tenantId, nip])
  @@index([tenantId, nip])
  @@index([tenantId])
}

// --- Documents & invoices (FVControl) ---

model Document {
  id               String             @id @default(uuid()) @db.Uuid
  tenantId         String             @db.Uuid
  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sha256           String
  storageKey       String
  storageBucket    String?
  mimeType         String
  sizeBytes        Int
  sourceType       IngestionSourceType?
  sourceExternalId String?
  metadata         Json?              @db.JsonB
  deletedAt        DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  updatedById      String?            @db.Uuid

  invoices       Invoice[]       @relation("InvoicePrimaryDocument")
  invoiceFiles   InvoiceFile[]
  extractionRuns ExtractionRun[]
  processingJobs ProcessingJob[]
  sourceAttachments SourceAttachment[]
  agreement         Agreement?

  @@unique([tenantId, sourceType, sourceExternalId])
  @@index([tenantId, sha256])
  @@index([tenantId])
  @@map("documents")
}

model Agreement {
  id                String            @id @default(uuid()) @db.Uuid
  tenantId          String            @db.Uuid
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contractorId      String?           @db.Uuid
  contractor        Contractor?       @relation(fields: [contractorId], references: [id], onDelete: SetNull)
  primaryDocId      String            @unique @db.Uuid
  primaryDoc        Document          @relation(fields: [primaryDocId], references: [id], onDelete: Cascade)
  title             String
  subject           String?
  counterpartyName  String?
  counterpartyNip   String?
  signedAt          DateTime?         @db.Date
  validUntil        DateTime?         @db.Date
  status            AgreementStatus   @default(PROCESSING)
  notes             String?
  normalizedPayload Json?             @db.JsonB
  createdById       String            @db.Uuid
  createdBy         User              @relation("AgreementCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("agreements")
}

model Invoice {
  id            String        @id @default(uuid()) @db.Uuid
  tenantId      String        @db.Uuid
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contractorId  String?       @db.Uuid
  contractor    Contractor?   @relation(fields: [contractorId], references: [id], onDelete: Restrict)
  primaryDocId  String?       @db.Uuid
  primaryDoc    Document?     @relation("InvoicePrimaryDocument", fields: [primaryDocId], references: [id], onDelete: SetNull)
  number        String
  issueDate     DateTime      @db.Date
  saleDate      DateTime?     @db.Date
  dueDate       DateTime?     @db.Date
  currency      String        @default("PLN")
  netTotal      Decimal       @db.Decimal(14, 2)
  vatTotal      Decimal       @db.Decimal(14, 2)
  grossTotal    Decimal       @db.Decimal(14, 2)
  status        InvoiceStatus
  source        InvoiceSource @default(MANUAL)
  /// Canonical ingestion channel when known
  ingestionKind IngestionSourceType?
  sourceExternalId String?
  /// NIP|number|issueDate|gross|currency — hashed in service layer
  fingerprint      String?
  notes            String?
  createdById      String        @db.Uuid
  createdBy        User          @relation("InvoiceCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  updatedById      String?       @db.Uuid

  /// Compliance / KSeF filter layer (see docs/compliance-rules.md)
  ledgerKind        InvoiceLedgerKind       @default(PURCHASE) @map("ledger_kind")
  intakeSourceType  InvoiceIntakeSourceType @default(UPLOAD) @map("intake_source_type")
  sourceAccount     String?                 @map("source_account")
  documentKind      InvoiceDocumentKind     @default(OTHER) @map("document_kind")
  legalChannel      LegalChannel            @default(UNKNOWN) @map("legal_channel")
  ksefRequired      Boolean                 @default(false) @map("ksef_required")
  ksefStatus        KsefWorkflowStatus      @default(NOT_APPLICABLE) @map("ksef_status")
  ksefNumber        String?                 @map("ksef_number")
  ksefReferenceId   String?                 @map("ksef_reference_id")
  ocrConfidence     Decimal?                @map("ocr_confidence") @db.Decimal(5, 4)
  duplicateHash     String?                 @map("duplicate_hash")
  duplicateScore    Decimal?                @map("duplicate_score") @db.Decimal(5, 4)
  reviewStatus      InvoiceReviewStatus     @default(NEW) @map("review_status")
  accountingStatus  AccountingRecordStatus  @default(NOT_EXPORTED) @map("accounting_status")
  rawPayload        Json?                   @map("raw_payload") @db.JsonB
  normalizedPayload Json?                   @map("normalized_payload") @db.JsonB
  complianceFlags   Json?                   @map("compliance_flags") @db.JsonB
  /// Kategoria raportowa (wydatki / przychody) — ustawiana ręcznie w UI; agregacja w Raportach.
  reportCategory    String?                 @map("report_category") @db.VarChar(200)

  items            InvoiceItem[]
  files            InvoiceFile[]
  events           InvoiceEvent[]
  links            InvoiceLink[]
  duplicatesAsA    InvoiceDuplicate[] @relation("DupCandidate")
  duplicatesAsB    InvoiceDuplicate[] @relation("DupCanonical")
  extractionRuns   ExtractionRun[]
  processingJobs   ProcessingJob[]
  sourceRecords    InvoiceSourceRecord[]
  complianceTrail  InvoiceComplianceEvent[]

  @@unique([tenantId, number])
  @@unique([tenantId, ingestionKind, sourceExternalId])
  @@index([tenantId, issueDate])
  @@index([tenantId, status])
  @@index([tenantId, fingerprint])
  @@index([tenantId, intakeSourceType])
  @@index([tenantId, ledgerKind])
  @@index([tenantId, ksefStatus])
  @@index([tenantId, reviewStatus])
  @@index([tenantId])
  @@index([contractorId])
}

model InvoiceItem {
  id         String   @id @default(uuid()) @db.Uuid
  invoiceId  String   @db.Uuid
  invoice    Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  name       String
  quantity   Decimal  @db.Decimal(12, 3)
  unit       String?
  netPrice   Decimal  @db.Decimal(14, 2)
  vatRate    Decimal  @db.Decimal(5, 2)
  netValue   Decimal  @db.Decimal(14, 2)
  grossValue Decimal  @db.Decimal(14, 2)

  @@index([invoiceId])
}

model InvoiceFile {
  id          String      @id @default(uuid()) @db.Uuid
  invoiceId   String      @db.Uuid
  invoice     Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  documentId  String?     @db.Uuid
  document    Document?   @relation(fields: [documentId], references: [id], onDelete: SetNull)
  storageType StorageType
  path        String
  mimeType    String
  sizeBytes   Int
  sha256      String
  uploadedAt  DateTime    @default(now())

  fileKind       InvoiceFileKind? @map("file_kind")
  storageUrl     String?          @map("storage_url")
  xmlPayload     String?          @map("xml_payload") @db.Text
  pdfPreviewUrl  String?          @map("pdf_preview_url")
  originalSha256 String?          @map("original_sha256")
  ocrText        String?          @map("ocr_text") @db.Text
  isPrimary      Boolean          @default(false) @map("is_primary")

  @@index([invoiceId])
  @@index([documentId])
}

model InvoiceEvent {
  id          String           @id @default(uuid()) @db.Uuid
  invoiceId   String           @db.Uuid
  invoice     Invoice          @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  actorUserId String?          @db.Uuid
  actor       User?            @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  type        InvoiceEventType
  payload     Json             @db.JsonB
  createdAt   DateTime         @default(now())

  @@index([invoiceId, createdAt])
}

model InvoiceLink {
  id             String             @id @default(uuid()) @db.Uuid
  invoiceId      String             @db.Uuid
  invoice        Invoice            @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  targetSystem   IngestionSourceType
  externalId     String
  metadata       Json?              @db.JsonB
  createdAt      DateTime           @default(now())

  @@unique([invoiceId, targetSystem, externalId])
  @@index([invoiceId])
  @@map("invoice_links")
}

model InvoiceDuplicate {
  id                 String              @id @default(uuid()) @db.Uuid
  tenantId           String              @db.Uuid
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  candidateInvoiceId String              @db.Uuid
  candidate          Invoice             @relation("DupCandidate", fields: [candidateInvoiceId], references: [id], onDelete: Cascade)
  canonicalInvoiceId String              @db.Uuid
  canonical          Invoice             @relation("DupCanonical", fields: [canonicalInvoiceId], references: [id], onDelete: Cascade)
  confidence         Decimal             @db.Decimal(5, 4)
  reasonCodes        Json                @db.JsonB
  resolution         DuplicateResolution @default(OPEN)
  resolvedById       String?             @db.Uuid
  resolvedAt         DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([tenantId, resolution])
  @@index([candidateInvoiceId])
  @@map("invoice_duplicates")
}

model ExtractionRun {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documentId  String   @db.Uuid
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  invoiceId   String?  @db.Uuid
  invoice     Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  provider    String
  model       String?
  rawJson     Json?    @db.JsonB
  confidence  Decimal? @db.Decimal(5, 4)
  errorCode   String?
  createdAt   DateTime @default(now())

  @@index([documentId])
  @@index([invoiceId])
  @@map("extraction_runs")
}

model ProcessingJob {
  id            String              @id @default(uuid()) @db.Uuid
  tenantId      String              @db.Uuid
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  queueName     String
  bullJobId     String?
  type          String
  status        ProcessingJobStatus @default(PENDING)
  currentStep   PipelineStep?
  attemptCount  Int                 @default(0)
  maxAttempts   Int                 @default(8)
  correlationId String
  payload       Json                @db.JsonB
  lastError     String?
  documentId    String?             @db.Uuid
  document      Document?           @relation(fields: [documentId], references: [id], onDelete: SetNull)
  invoiceId     String?             @db.Uuid
  invoice       Invoice?            @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  attempts ProcessingAttempt[]

  @@index([tenantId, status])
  @@index([correlationId])
  @@map("processing_jobs")
}

model ProcessingAttempt {
  id         String   @id @default(uuid()) @db.Uuid
  jobId      String   @db.Uuid
  job        ProcessingJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  attemptNo  Int
  step       PipelineStep
  errorClass String?
  message    String?
  startedAt  DateTime @default(now())
  endedAt    DateTime?

  @@index([jobId])
  @@map("processing_attempts")
}

// --- Mail & ingestion registry ---

model Mailbox {
  id             String          @id @default(uuid()) @db.Uuid
  tenantId       String          @db.Uuid
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider       MailboxProvider
  label          String
  credentialId   String?         @db.Uuid
  credential     IntegrationCredential? @relation(fields: [credentialId], references: [id], onDelete: SetNull)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  syncState      MailboxSyncState?
  sourceMessages SourceMessage[]

  @@unique([tenantId, provider, label])
  @@index([tenantId])
  @@map("mailboxes")
}

model MailboxSyncState {
  id              String   @id @default(uuid()) @db.Uuid
  mailboxId       String   @unique @db.Uuid
  mailbox         Mailbox  @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  historyId       String?
  uidValidity     Int?
  uidNext         Int?
  lastSyncedAt    DateTime?
  lastError       String?
  /// Zenbox IMAP: IDLE | RUNNING | ERROR
  imapSyncStatus      ImapMailboxSyncStatus @default(IDLE) @map("imap_sync_status")
  /// Last successfully processed IMAP UID (inclusive cursor).
  imapLastProcessedUid BigInt?              @map("imap_last_processed_uid")
  /// UIDVALIDITY from server (string for forward-compat).
  imapUidValidityStr   String?              @map("imap_uid_validity_str")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([mailboxId, imapLastProcessedUid])
  @@map("mailbox_sync_state")
}

model IngestionSource {
  id        String             @id @default(uuid()) @db.Uuid
  tenantId  String             @db.Uuid
  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kind      IngestionSourceType
  label     String
  isEnabled Boolean            @default(true)
  metadata  Json?              @db.JsonB
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@unique([tenantId, kind, label])
  @@index([tenantId])
  @@map("ingestion_sources")
}

// --- Integrations ---

model IntegrationPos {
  id              String      @id @default(uuid()) @db.Uuid
  tenantId        String      @db.Uuid
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider        PosProvider
  baseUrl         String
  apiKeyEncrypted String
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([tenantId, provider])
  @@index([tenantId])
}

model IntegrationCredential {
  id           String                   @id @default(uuid()) @db.Uuid
  tenantId     String                   @db.Uuid
  tenant       Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connector    ConnectorType
  kind         IntegrationCredentialKind
  label        String
  secretEncrypted String
  /// Encryption / rotation bookkeeping (increment on credential rotation).
  keyVersion   Int                      @default(1) @map("key_version")
  metadata     Json?                    @db.JsonB
  rotatedAt    DateTime?
  expiresAt    DateTime?
  isActive     Boolean                  @default(true)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  createdById  String?                  @db.Uuid

  mailboxes Mailbox[]

  @@unique([tenantId, connector, label])
  @@index([tenantId])
  @@map("integration_credentials")
}

model SourceMessage {
  id                String                  @id @default(uuid()) @db.Uuid
  tenantId          String                  @db.Uuid
  tenant            Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider          IngestionChannelProvider
  accountKey        String                  @map("account_key")
  mailboxId         String?                 @db.Uuid
  mailbox           Mailbox?                @relation(fields: [mailboxId], references: [id], onDelete: SetNull)
  externalMessageId String                  @map("external_message_id")
  imapUid           BigInt                  @map("imap_uid")
  receivedAt        DateTime                @map("received_at")
  subject           String?
  fromAddress       String?                 @map("from_address")
  rawHeaders        Json?                   @map("raw_headers") @db.JsonB
  processedAt       DateTime?               @map("processed_at")
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  attachments       SourceAttachment[]

  @@unique([tenantId, provider, accountKey, externalMessageId])
  @@index([tenantId, provider, accountKey])
  @@index([tenantId, provider, accountKey, imapUid])
  @@map("source_messages")
}

model SourceAttachment {
  id                 String        @id @default(uuid()) @db.Uuid
  sourceMessageId    String        @map("source_message_id") @db.Uuid
  sourceMessage      SourceMessage @relation(fields: [sourceMessageId], references: [id], onDelete: Cascade)
  fileName           String        @map("file_name")
  mimeType           String        @map("mime_type")
  sizeBytes          Int           @map("size_bytes")
  sha256             String
  storageUrl         String        @map("storage_url")
  isInvoiceCandidate Boolean       @default(false) @map("is_invoice_candidate")
  documentId         String?       @map("document_id") @db.Uuid
  document           Document?     @relation(fields: [documentId], references: [id], onDelete: SetNull)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@unique([sourceMessageId, sha256])
  @@index([sourceMessageId])
  @@index([documentId])
  @@map("source_attachments")
}

model BillingWebhookEvent {
  id         String                 @id @default(uuid()) @db.Uuid
  provider   BillingWebhookProvider
  eventId    String
  payload    Json                   @db.JsonB
  receivedAt DateTime               @default(now()) @map("received_at")

  @@unique([provider, eventId])
  @@index([receivedAt])
  @@map("billing_webhook_events")
}

model AuditLog {
  id         String           @id @default(uuid()) @db.Uuid
  tenantId   String           @db.Uuid
  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorId    String?          @db.Uuid
  actor      User?            @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  entityType AuditEntityType
  entityId   String?
  metadata   Json             @db.JsonB
  ip         String?
  requestId  String?
  createdAt  DateTime         @default(now())

  @@index([tenantId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model InvoiceSourceRecord {
  id               String                @id @default(uuid()) @db.Uuid
  tenantId         String                @db.Uuid
  tenant           Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceId        String?               @db.Uuid
  invoice          Invoice?              @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  intakeSourceType InvoiceIntakeSourceType @map("intake_source_type")
  sourceAccount    String?               @map("source_account")
  externalRef      String?               @map("external_ref")
  metadata         Json?                 @db.JsonB
  createdAt        DateTime              @default(now())

  @@index([tenantId, intakeSourceType])
  @@index([invoiceId])
  @@map("invoice_sources")
}

model InvoiceComplianceEvent {
  id         String              @id @default(uuid()) @db.Uuid
  tenantId   String              @db.Uuid
  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceId  String              @db.Uuid
  invoice    Invoice             @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  eventType  ComplianceEventType @map("event_type")
  payload    Json                @db.JsonB
  createdAt  DateTime            @default(now())

  @@index([tenantId, invoiceId])
  @@index([invoiceId, createdAt])
  @@map("invoice_compliance_events")
}

model AccountingExport {
  id             String                 @id @default(uuid()) @db.Uuid
  tenantId       String                 @db.Uuid
  tenant         Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  status         AccountingExportStatus @default(PENDING)
  invoiceIds     Json                   @db.JsonB
  packageSummary Json?                  @map("package_summary") @db.JsonB
  createdById    String?                @map("created_by_id") @db.Uuid
  createdAt      DateTime               @default(now())

  @@index([tenantId, createdAt])
  @@map("accounting_exports")
}

model IdempotencyKey {
  id               String               @id @default(uuid()) @db.Uuid
  tenantId         String               @db.Uuid
  tenant           Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  idempotencyKey   String               @map("idempotency_key")
  routeFingerprint String               @map("route_fingerprint")
  requestHash      String
  lifecycle        IdempotencyLifecycle @default(IN_FLIGHT)
  responseStatus   Int?
  responseBody     Json?                @db.JsonB
  createdAt        DateTime             @default(now())
  expiresAt        DateTime

  @@unique([tenantId, idempotencyKey, routeFingerprint])
  @@index([expiresAt])
  @@index([tenantId, lifecycle])
  @@map("idempotency_keys")
}

model TenantSetting {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key       String
  valueJson Json     @db.JsonB
  updatedAt DateTime @updatedAt
  updatedById String? @db.Uuid

  @@unique([tenantId, key])
  @@map("tenant_settings")
}
