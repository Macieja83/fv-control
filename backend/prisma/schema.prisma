generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  ACCOUNTANT
  VIEWER
}

enum InvoiceStatus {
  DRAFT
  RECEIVED
  VERIFIED
  PAID
  REJECTED
}

enum InvoiceSource {
  MANUAL
  OCR
  EMAIL
  API
}

enum StorageType {
  LOCAL
  S3
}

enum InvoiceEventType {
  CREATED
  UPDATED
  STATUS_CHANGED
  FILE_ADDED
  FILE_REMOVED
  EXPORTED
}

enum PosProvider {
  POS_RESTA
}

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  nip       String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  contractors       Contractor[]
  invoices          Invoice[]
  integrationsPos   IntegrationPos[]
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email        String   @unique
  passwordHash String
  role         UserRole
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens    RefreshToken[]
  invoicesCreated  Invoice[]       @relation("InvoiceCreatedBy")
  invoiceEvents    InvoiceEvent[]

  @@index([tenantId])
}

model RefreshToken {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String    @unique
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?
  replacedById String?  @db.Uuid

  @@index([userId])
  @@index([expiresAt])
}

model Contractor {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @db.Uuid
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  nip       String
  address   String?
  email     String?
  phone     String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  invoices Invoice[]

  @@unique([tenantId, nip])
  @@index([tenantId, nip])
  @@index([tenantId])
}

model Invoice {
  id            String        @id @default(uuid()) @db.Uuid
  tenantId      String        @db.Uuid
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contractorId  String        @db.Uuid
  contractor    Contractor    @relation(fields: [contractorId], references: [id], onDelete: Restrict)
  number        String
  issueDate     DateTime      @db.Date
  saleDate      DateTime?     @db.Date
  dueDate       DateTime?     @db.Date
  currency      String        @default("PLN")
  netTotal      Decimal       @db.Decimal(14, 2)
  vatTotal      Decimal       @db.Decimal(14, 2)
  grossTotal    Decimal       @db.Decimal(14, 2)
  status        InvoiceStatus
  source        InvoiceSource @default(MANUAL)
  notes         String?
  createdById   String        @db.Uuid
  createdBy     User          @relation("InvoiceCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  items  InvoiceItem[]
  files  InvoiceFile[]
  events InvoiceEvent[]

  @@unique([tenantId, number])
  @@index([tenantId, issueDate])
  @@index([tenantId])
  @@index([contractorId])
}

model InvoiceItem {
  id         String   @id @default(uuid()) @db.Uuid
  invoiceId  String   @db.Uuid
  invoice    Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  name       String
  quantity   Decimal  @db.Decimal(12, 3)
  unit       String?
  netPrice   Decimal  @db.Decimal(14, 2)
  vatRate    Decimal  @db.Decimal(5, 2)
  netValue   Decimal  @db.Decimal(14, 2)
  grossValue Decimal  @db.Decimal(14, 2)

  @@index([invoiceId])
}

model InvoiceFile {
  id          String      @id @default(uuid()) @db.Uuid
  invoiceId   String      @db.Uuid
  invoice     Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  storageType StorageType
  path        String
  mimeType    String
  sizeBytes   Int
  sha256      String
  uploadedAt  DateTime    @default(now())

  @@index([invoiceId])
}

model InvoiceEvent {
  id          String           @id @default(uuid()) @db.Uuid
  invoiceId   String           @db.Uuid
  invoice     Invoice          @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  actorUserId String?          @db.Uuid
  actor       User?            @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  type        InvoiceEventType
  payload     Json             @db.JsonB
  createdAt   DateTime         @default(now())

  @@index([invoiceId, createdAt])
}

model IntegrationPos {
  id               String      @id @default(uuid()) @db.Uuid
  tenantId         String      @db.Uuid
  tenant           Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider         PosProvider
  baseUrl          String
  apiKeyEncrypted  String
  isActive         Boolean     @default(true)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@unique([tenantId, provider])
  @@index([tenantId])
}
