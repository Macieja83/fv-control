# =============================================================================
# PRODUCTION — publiczna sprzedaż subskrypcji i dane klientów.
# Skopiuj do sekretów hosta (nie commituj). Pełna dokumentacja pól: `.env.example`.
# =============================================================================

NODE_ENV=production
DATABASE_URL=postgresql://USER:PASS@prod-db.example:5432/fvresta?schema=public
REDIS_URL=redis://prod-redis.example:6379

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ENCRYPTION_KEY=

CORS_ORIGINS=https://app.twojadomena.pl
WEB_APP_URL=https://app.twojadomena.pl

# Wymagane do rejestracji i aktywacji konta (link e-mail + Google OAuth → link).
# Gmail: smtp.gmail.com:587, SMTP_SECURE=false — SMTP_USER / hasło aplikacji jak w Zenbox (IMAP) w panelu.
# Własny SMTP: np. SMTP_HOST=smtp.twojadomena.pl i EMAIL_FROM z tej domeny.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=FV Resta <noreply@twojadomena.pl>
AUTH_EXPOSE_VERIFICATION_TOKEN=false

METRICS_BEARER_TOKEN=
FEATURE_AI_EXTRACTION_MOCK=false
OPENAI_API_KEY=

# KSeF produkcja MF — tylko po zatwierdzeniu checklisty MF
KSEF_ENV=production
KSEF_DISABLE_GLOBAL_FALLBACK=true
KSEF_ISSUANCE_MODE=stub

# Stripe LIVE
STRIPE_SECRET_KEY=sk_live_
STRIPE_PRICE_ID_PRO=price_
STRIPE_BILLING_WEBHOOK_SECRET=whsec_

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://api.twojadomena.pl/api/v1/auth/google/callback

PLATFORM_ADMIN_EMAIL=

STORAGE_DRIVER=s3
S3_ENDPOINT=
S3_REGION=eu-central-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_FORCE_PATH_STYLE=false
