{
  "name": "fv-resta-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "worker": "tsx watch src/worker.ts",
    "worker:start": "node dist/worker.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"prisma/**/*.ts\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "verify:openai": "node scripts/verify-openai-connection.mjs",
    "refresh:dup-compliance": "tsx scripts/refresh-open-duplicate-compliance.ts",
    "repair:dup-orientation": "tsx scripts/repair-invoice-duplicate-orientation.ts",
    "diagnose:invoices": "tsx scripts/diagnose-invoices.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.721.0",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^12.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.1",
    "@prisma/client": "^6.3.1",
    "argon2": "^0.41.1",
    "bullmq": "^5.34.3",
    "dotenv": "^16.4.7",
    "fast-xml-parser": "^4.5.6",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "imapflow": "^1.2.18",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.9.6",
    "openai": "^6.33.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "prom-client": "^15.1.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.7",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "prisma": "^6.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0",
    "vitest": "^3.0.4"
  }
}
