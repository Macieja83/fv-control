# Runtime
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
APP_NAME=FV Resta API
APP_VERSION=1.0.0

# Database (PostgreSQL)
DATABASE_URL=postgresql://fvresta:fvresta@localhost:5432/fvresta?schema=public

# JWT — use long random strings in production (min 32 chars each)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-characters-long!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-characters-long!
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=30

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Local file uploads
UPLOAD_DIR=./storage/uploads
MAX_UPLOAD_MB=25

# AES-256-GCM for POS API keys at rest — must be base64 of exactly 32 bytes
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=AQEBAQEBAQEBAQEBAQEBAQEBAQEBAQEBAQEBAQEBAQE=

# Logging
LOG_LEVEL=info

# Rate limit: login endpoint
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_LOGIN_WINDOW_MS=60000
