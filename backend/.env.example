# =============================================================================
# FVControl — environment template (dev / staging / prod)
# Copy to `.env` locally. Never commit real secrets.
# =============================================================================

# --- Runtime ---
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
APP_NAME=FVControl API
APP_VERSION=1.0.0

# --- Database ---
DATABASE_URL=postgresql://fvresta:fvresta@localhost:5432/fvresta?schema=public

# --- JWT (separate secrets; min 32 chars; rotate on breach) ---
JWT_ACCESS_SECRET=change-me-access-secret-min-32-characters-long!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-characters-long!
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=30

# --- Encryption at rest (integration credentials, OAuth tokens)
# Base64 of exactly 32 bytes. Generate: openssl rand -base64 32
ENCRYPTION_KEY=AQEBAQEBAQEBAQEBAQEBAQEBAQEBAQEBAQEBAQEBAQE=

# --- CORS (comma-separated allowlist) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# --- Uploads & objects (local driver by default) ---
UPLOAD_DIR=./storage/uploads
MAX_UPLOAD_MB=25
# Max size for GET …/invoices/:id/primary-document (streaming preview)
MAX_DOCUMENT_PREVIEW_MB=35
STORAGE_DRIVER=local

# --- S3-compatible (MinIO / AWS / other) — used when STORAGE_DRIVER=s3 ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123456
S3_BUCKET=fvcontrol-documents
S3_FORCE_PATH_STYLE=true

# --- Redis & BullMQ ---
REDIS_URL=redis://127.0.0.1:6379
BULLMQ_PREFIX=fvcontrol

# --- Zenbox IMAP (ImapFlow) — optional tuning ---
IMAP_FLOW_CONNECTION_TIMEOUT_MS=60000
IMAP_FLOW_GREETING_TIMEOUT_MS=16000
IMAP_FLOW_SOCKET_TIMEOUT_MS=120000
IMAP_ZENBOX_FETCH_BATCH_SIZE=25
IMAP_ZENBOX_MAX_BATCHES_PER_JOB=40
IMAP_ZENBOX_LOCK_TTL_SEC=600

# --- Pipeline / AI extraction ---
FEATURE_AI_EXTRACTION_MOCK=true
PIPELINE_MAX_ATTEMPTS=8

# --- OpenAI (real PDF/image extraction — set API key to enable) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- IMAP auto-sync interval (ms, 0 = disabled) ---
IMAP_AUTO_SYNC_INTERVAL_MS=300000

# --- Inbound webhooks (n8n) optional HMAC ---
# Min 16 chars if set; leave unset to allow unsigned in trusted dev nets only
WEBHOOK_SIGNING_SECRET=

# --- Rate limits ---
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_LOGIN_WINDOW_MS=60000
RATE_LIMIT_WEBHOOK_MAX=120
RATE_LIMIT_WEBHOOK_WINDOW_MS=60000

# --- Logging ---
LOG_LEVEL=info

# --- Optional integrations (stubs until connectors implemented) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KSEF_ENV=mock
RESTA_API_BASE_URL=

# --- Compliance (simplified receipt thresholds; PLN / EUR) ---
SIMPLIFIED_RECEIPT_MAX_PLN=450
SIMPLIFIED_RECEIPT_MAX_EUR=100

# --- n8n / outbound compliance events (optional default URL for outbox enqueue) ---
N8N_WEBHOOK_URL=

# --- Idempotency cache TTL for POST/PATCH replay (Idempotency-Key header) ---
IDEMPOTENCY_TTL_HOURS=24

# --- Outbound webhook worker (runs inside `npm run worker`) ---
WEBHOOK_DELIVERY_INTERVAL_MS=5000
WEBHOOK_DELIVERY_MAX_ATTEMPTS=10
WEBHOOK_HTTP_TIMEOUT_MS=15000
WEBHOOK_MAX_SKEW_SECONDS=300
WEBHOOK_OUTBOX_SENT_RETENTION_DAYS=90
WEBHOOK_PROCESSING_STALE_MS=900000
HOUSEKEEPING_INTERVAL_MS=60000
