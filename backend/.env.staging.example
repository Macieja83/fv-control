# =============================================================================
# STAGING — kopia szablonu pod środowisko przedprodukcyjne (dane testowe).
# Skopiuj do `.env` na hoście staging / w sekretach CI. Pełna lista pól: `.env.example`.
# =============================================================================

NODE_ENV=production
DATABASE_URL=postgresql://USER:PASS@staging-db.example:5432/fvresta?schema=public
REDIS_URL=redis://staging-redis.example:6379

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ENCRYPTION_KEY=

CORS_ORIGINS=https://staging-app.example.com
WEB_APP_URL=https://staging-app.example.com

METRICS_BEARER_TOKEN=
FEATURE_AI_EXTRACTION_MOCK=false
OPENAI_API_KEY=

# KSeF: sandbox MF; bez globalnego fallbacku dla tenantów SaaS
KSEF_ENV=sandbox
KSEF_DISABLE_GLOBAL_FALLBACK=true
KSEF_ISSUANCE_MODE=stub

# Stripe TEST (staging)
STRIPE_SECRET_KEY=sk_test_
STRIPE_PRICE_ID_PRO=price_
STRIPE_BILLING_WEBHOOK_SECRET=whsec_

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://staging-api.example.com/api/v1/auth/google/callback

PLATFORM_ADMIN_EMAIL=

STORAGE_DRIVER=s3
S3_ENDPOINT=
S3_REGION=eu-central-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_FORCE_PATH_STYLE=false
