# Nadpisywane przez `npm run dev:web` (Vite: `--mode web-only`).
# W połączeniu z lokalnym `.env` wycisza prawdziwe API i włącza logowanie dev w Vite.
#
# Logowanie: dowolny e-mail (o ile w `.env` nie wymusisz FV_RESTA_LOGIN_EMAIL) + FV_RESTA_LOGIN_PASSWORD poniżej.
FV_RESTA_API_URL=
FV_RESTA_LOGIN_PASSWORD=Admin123!
VITE_USE_MOCK_INVOICES=true
