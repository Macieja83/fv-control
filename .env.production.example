# Kopiuj na VPS jako `.env.production` (nie commituj tego pliku — jest w .gitignore).
# Vite wczytuje go przy `npm run build` (tryb production).
#
VITE_PLAUSIBLE_DOMAIN=fv.resta.biz
# Opcjonalnie: własny host skryptu Plausible (np. self-hosted EU).
# VITE_PLAUSIBLE_SCRIPT_SRC=https://plausible.io/js/script.js
#
# Opcjonalnie: pełny URL embedu Calendly (iframe). Bez tego sekcja demo się nie pokaże.
# VITE_CALENDLY_EMBED_URL=https://calendly.com/twoj-slug/30min
